# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio number in E.164 format — single caller ID for all test calls
TWILIO_PHONE_NUMBER=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Target (do not change for this assessment) ---
TARGET_PHONE_NUMBER=+18054398008

# --- Server ---
# Public HTTPS URL Twilio can reach (ngrok or deployed host, no trailing slash)
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app
HOST=0.0.0.0
PORT=8000

# --- OpenAI Realtime (patient voice during call) ---
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=shimmer

# --- OpenAI Chat (orchestrator, generator, bug evaluator) ---
OPENAI_PLANNING_MODEL=gpt-4o
OPENAI_EVAL_MODEL=gpt-4o

# --- Whisper (post-call transcription) ---
WHISPER_MODEL=whisper-1

# --- Call behavior ---
MAX_CALL_DURATION_SECONDS=180
RESPONSE_DELAY_MS=400
CALL_RING_TIMEOUT_SECONDS=30
VAD_SILENCE_DURATION_MS=1200
AGENT_TURN_COOLDOWN_MS=600
PATIENT_PLAYBACK_HOLD_MS=800

# Phase 3 media bridge: silent (default) or echo (debug bidirectional audio)
MEDIA_BRIDGE_MODE=silent

# --- Output paths ---
# Root folder for all run artifacts (default: outputs).
# Each call is stored in its own subfolder, e.g. outputs/call01/:
#   call01-scenario.json
#   call01-recording.mp3
#   call01-transcript.txt
#   call01-transcript-full.json
#   call01-session.json
#   call01-events.json
#   call01-bugs.md
# Shared index files at the root of OUTPUT_DIR:
#   bug_report.md
#   call_history.json
OUTPUT_DIR=outputs

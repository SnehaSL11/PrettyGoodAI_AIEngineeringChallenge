# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio number in E.164 format — single caller ID for all test calls
TWILIO_PHONE_NUMBER=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Target (do not change for this assessment) ---
TARGET_PHONE_NUMBER=+18054398008

# --- Server ---
# Public HTTPS URL Twilio can reach (ngrok or deployed host, no trailing slash)
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app
HOST=0.0.0.0
PORT=8000

# --- OpenAI Realtime (patient voice during call) ---
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=shimmer

# --- OpenAI Chat (orchestrator, generator, bug evaluator) ---
OPENAI_PLANNING_MODEL=gpt-4o
OPENAI_EVAL_MODEL=gpt-4o

# --- Whisper (post-call transcription) ---
WHISPER_MODEL=whisper-1

# --- Call behavior ---
MAX_CALL_DURATION_SECONDS=180
RESPONSE_DELAY_MS=400
CALL_RING_TIMEOUT_SECONDS=30

# --- Paths ---
OUTPUT_DIR=outputs
